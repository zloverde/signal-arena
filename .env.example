# Signal Arena — Environment Variables
# Copy this file to .env.local and fill in your values

# Supabase — get these from your project's Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key   # Use service role (not anon) for server operations

# Admin key — choose a strong secret for admin endpoint access
ADMIN_SECRET_KEY=change-this-to-a-strong-secret

# App URL — used for server-side fetch calls
NEXT_PUBLIC_APP_URL=http://localhost:3000    # Change to your Vercel URL in production

# Anthropic — required for /api/cron/create-rounds (Claude round proposals)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Optional: protect cron routes with Authorization: Bearer <CRON_SECRET>
# CRON_SECRET=your-cron-secret
